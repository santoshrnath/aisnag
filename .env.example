# =============================================================================
# SnagPin — environment template
# =============================================================================
# Copy this file to `.env.local` for local dev, or to `.env` for docker compose.
# NEVER commit a file containing real secrets — `.gitignore` covers all
# common variants (.env, .env.local, .env.production, .env.*.local).
# =============================================================================

# ---- Anthropic (Claude) — required ----------------------------------------
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-replace-me
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Clerk (auth) — optional ----------------------------------------------
# Without these, the app runs in open demo mode (read-only against the
# default tenant; AI endpoints unrestricted). With them, AI photo-to-snag,
# voice-to-snag and semantic search are gated to signed-in users.
# Get keys at https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Comma-separated emails — these users see across all tenants.
SUPER_ADMIN_EMAILS=

# ---- Database --------------------------------------------------------------
# Default points at the snagpin-db container in docker-compose.
# For pure-Node dev: postgresql://snagpin:snagpin@localhost:5432/snagpin?schema=public
DATABASE_URL=postgresql://snagpin:snagpin@snagpin-db:5432/snagpin?schema=public

# ---- Vector database -------------------------------------------------------
# "qdrant" hits the snagpin-qdrant container (recommended).
# "pgvector" uses Postgres only — handy if you don't want to run Qdrant.
VECTOR_DB_PROVIDER=qdrant
QDRANT_URL=http://snagpin-qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=snag_chunks

# ---- Object storage --------------------------------------------------------
# "local" — files land in /app/storage-local (great for first-run).
# "s3"    — Hetzner Storage Box / any S3-compatible endpoint.
STORAGE_PROVIDER=local

S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_REGION=fsn1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_DRAWINGS=snag-drawings
S3_BUCKET_PHOTOS=snag-photos
S3_BUCKET_AUDIO=snag-audio
S3_FORCE_PATH_STYLE=true

# ---- Embeddings ------------------------------------------------------------
# Local Xenova model — no API key, downloads ~30MB on first run.
# Swap to Voyage AI (Anthropic's recommended partner) or OpenAI for hosted.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3-lite
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---- Upload limits ---------------------------------------------------------
MAX_UPLOAD_SIZE_MB=25

# ---- Deployment ------------------------------------------------------------
SNAGPIN_PORT=3080
PUBLIC_HOSTNAME=aisnag.oneplaceplatform.com
TRAEFIK_NETWORK=coolify
